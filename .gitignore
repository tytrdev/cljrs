*.o
*.a
*.so
*.dylib
*.dll
*.exe

# MLIR dumps (when --dump passes are enabled during debug)
*.mlir.dump
*.ll

# Profiling output
*.profraw
*.profdata

# Temp work
/tmp/
*.tmp
*.bak

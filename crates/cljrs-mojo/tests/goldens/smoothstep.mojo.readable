# cljrs: (defn-mojo smoothstep (__tagged__ f32 [(__tagged__ f32 edge0) (__tagged__ f32 edge1) (__tagged__ f32 x)]) (let [t (max 0.0 (min 1.0 (/ (- x edge0) (- edge1 edge0))))] (* t (* t (- 3.0 (* 2.0 t))))))
fn smoothstep(edge0: Float32, edge1: Float32, x: Float32) -> Float32:
    var t = max(0.0, min(1.0, ((x - edge0) / (edge1 - edge0))))
    return (t * (t * (3.0 - (2.0 * t))))
